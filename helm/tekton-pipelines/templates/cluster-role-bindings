{{- range .Values.clusterRoleBindings }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ .name }}
  namespace: {{ $.Values.namespace }}
subjects:
  {{- range .subjects }}
  - kind: {{ .kind }}
    name: {{ .name }}
    namespace: {{ $.Values.namespace }}
  {{- end }}
roleRef:
  {{- toYaml .roleRef | nindent 2 }}
{{- end }}
